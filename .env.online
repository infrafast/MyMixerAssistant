# Online profile for Live Stage Assistant.
# Activate with: cp .env.online .env

# Cloud API keys
# Keep real keys outside Git. Create these local files and put only the secret value inside.
OPENAI_API_KEY_FILE=OPENAI_API_KEY.txt
ELEVENLABS_API_KEY_FILE=ELEVENLABS_API_KEY.txt

# LLM provider selection
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434

# Speech-to-text settings
STT_PROVIDER=openai-whisper
LOCAL_WHISPER_MODEL=base
STT_LANGUAGE=auto

# Text-to-speech settings
TTS_PROVIDER=elevenlabs
ELEVENLABS_VOICE_ID=1EmYoP3UnnnwhlJKovEy

# Audio settings
VOICE_SILENCE_THRESHOLD=500
VOICE_SILENCE_DURATION=1.5

# Assistant prompt
# Leave empty to use the built-in prompt from voice_assistant/agent.py.
ASSISTANT_SYSTEM_PROMPT=

# MCP configuration
MCP_CONFIG=mcp_servers.json

# Optional MCP-provided startup instructions
MCP_LOAD_SERVER_PROMPT=false
MCP_PROMPT_MERGE_MODE=append

# Optional MCP server credentials
LINEAR_API_KEY=your-linear-api-key-here
GITHUB_PERSONAL_ACCESS_TOKEN=your-github-token-here
GITLAB_PERSONAL_ACCESS_TOKEN=your-gitlab-token-here
GITLAB_BASE_URL=https://gitlab.com
POSTGRES_CONNECTION_STRING=postgresql://user:password@localhost:5432/dbname

# Logging
DEBUG=false
MCP_LOG_LEVEL=info
