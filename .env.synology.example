# Copy this file to synology/.env on the NAS and edit it there.

# Secrets are read from files mounted in /config.
OPENAI_API_KEY_FILE=/config/OPENAI_API_KEY.txt
ELEVENLABS_API_KEY_FILE=/config/ELEVENLABS_API_KEY.txt

# Recommended first Docker profile: online LLM/STT, optional ElevenLabs TTS.
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4.1-mini
OLLAMA_BASE_URL=http://127.0.0.1:11434

STT_PROVIDER=openai-whisper
LOCAL_WHISPER_MODEL=base
STT_LANGUAGE=fr
STT_PROMPT="Commandes courtes en français pour une console de mixage. Les commandes commencent souvent par: mets, met, règle, baisse, monte, coupe, mute, active, réactive. Ne colle pas le verbe 'mets' au nom qui suit: écris 'mets Claude', 'mets Voc-Claude', 'mets snare'."

# For DSM/headless Docker, start with none or elevenlabs.
# pyttsx3/local speaker output requires working /dev/snd passthrough.
TTS_PROVIDER=none
ELEVENLABS_VOICE_ID=1EmYoP3UnnnwhlJKovEy

VOICE_SILENCE_THRESHOLD=500
VOICE_SILENCE_DURATION=1.5
THINKING_SOUND_FILE=chatgpt.wav

WAKE_WORD=mixeur,mixer
ASSISTANT_SYSTEM_PROMPT=
MCP_AGENT_MEMORY_ENABLED=true

MCP_CONFIG=/config/mcp_servers.synology.json
MCP_LOAD_SERVER_PROMPT=true
MCP_PROMPT_MERGE_MODE=append

# If you mount a built XMSeries-MCP checkout at ./XMSeries-MCP:/xmseries-mcp:ro
XMSERIES_MCP_PATH=/xmseries-mcp

LINEAR_API_KEY=
GITHUB_PERSONAL_ACCESS_TOKEN=
GITLAB_PERSONAL_ACCESS_TOKEN=
GITLAB_BASE_URL=https://gitlab.com
POSTGRES_CONNECTION_STRING=

# Bind to all interfaces in a container so DSM/LAN can reach the monitor.
WEB_MONITOR_ENABLED=true
WEB_MONITOR_HOST=0.0.0.0
WEB_MONITOR_PORT=8765

DEBUG=false
MCP_LOG_LEVEL=info
