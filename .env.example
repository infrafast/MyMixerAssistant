# Required API Keys
# OpenAI API key for Whisper (speech-to-text) and GPT models
# Put the real key in this ignored local text file.
OPENAI_API_KEY_FILE=OPENAI_API_KEY.txt

# Optional but Recommended
# ElevenLabs API key for high-quality text-to-speech
# Without this, the assistant will use the system TTS (pyttsx3)
ELEVENLABS_API_KEY_FILE=ELEVENLABS_API_KEY.txt

# Optional - Model Settings
# OpenAI model for the assistant (default: gpt-4)
# Options: gpt-4, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4

# Optional - Speech-to-text Settings
STT_PROVIDER=openai-whisper
LOCAL_WHISPER_MODEL=base
STT_LANGUAGE=auto
STT_PROMPT="Commandes courtes en français pour une console de mixage. Les commandes commencent souvent par: mets, met, règle, baisse, monte, coupe, mute, active, réactive. Ne colle pas le verbe 'mets' au nom qui suit: écris 'mets Claude', 'mets Voc-Claude', 'mets snare'."

# Optional - Voice Settings
# ElevenLabs voice ID (default: Rachel)
# Browse available voices at https://elevenlabs.io/voice-library
# Voices shown in the web monitor dropdown. Format: voice_id (Display name), voice_id2 (Display name 2)
ELEVENLABS_VOICE_OPTIONS=kENkNtk0xyzG09WW40xE (Marcel), 1EmYoP3UnnnwhlJKovEy (Anthony), FFXYdAYPzn8Tw8KiHZqg (Ingrid), YxrwjAKoUKULGd0g8K9Y (Lucie)
ELEVENLABS_VOICE_ID=ZF6FPAbjXT4488VcRRnw

# Optional - Audio Settings
# Silence threshold for voice detection (default: 500)
# Lower values = more sensitive
VOICE_SILENCE_THRESHOLD=500

# Silence duration in seconds (default: 1.5)
# How long to wait after speech stops
VOICE_SILENCE_DURATION=1.5

# Optional experimental voice cancel while the assistant is thinking.
# When false, no extra microphone listener is started and behavior stays unchanged.
# When true, saying "stop", "annule", "annuler", "arrête", or "cancel" during thinking cancels the active request.
VOICE_CANCEL_DURING_THINKING=false

# WAV loop played while the LLM/MCP agent is processing a command.
# Bare filenames are resolved from assets/.
# Leave empty to disable the thinking sound.
THINKING_SOUND_FILE=thinking.wav

# Optional - Assistant Configuration
# Optional global wake word. Empty keeps the current behavior; when set, only matching transcriptions are processed.
# Multiple variants can be separated by comma, semicolon, or pipe.
WAKE_WORD=

# System prompt for the AI assistant
# Customize the assistant's personality and behavior
ASSISTANT_SYSTEM_PROMPT="You are a helpful voice assistant with access to various tools. Your name is mcp-use. Be concise in your responses since they will be spoken aloud. Summarize your results. Behave like a great motivational speaker, and motivate me throughout the conversation."
# Keep conversation memory enabled for context, but never use it as source of truth for live external state.
MCP_AGENT_MEMORY_ENABLED=true

# Optional - MCP-provided Assistant Instructions
# When enabled, the assistant loads startup instructions from assistantPrompt blocks in MCP_CONFIG.
MCP_LOAD_SERVER_PROMPT=false
# append keeps the local assistant prompt before the loaded MCP prompts; replace uses only the loaded MCP prompts.
MCP_PROMPT_MERGE_MODE=append

# Linear API key for task management integration
# The Linear MCP server can also use browser-based authentication
LINEAR_API_KEY=your-linear-api-key-here

# GitHub personal access token for GitHub MCP server
GITHUB_PERSONAL_ACCESS_TOKEN=your-github-token-here

# GitLab configuration for GitLab MCP server
GITLAB_PERSONAL_ACCESS_TOKEN=your-gitlab-token-here
GITLAB_BASE_URL=https://gitlab.com

# PostgreSQL connection string for database MCP server
POSTGRES_CONNECTION_STRING=postgresql://user:password@localhost:5432/dbname

# Optional - Development Settings
# Local web monitor for chat commands, state, active config, console logs, and final prompt.
WEB_MONITOR_ENABLED=true
WEB_MONITOR_HOST=127.0.0.1
WEB_MONITOR_PORT=8765

# Optional browser-side audio controls proxied through the backend.
# Backend TTS has priority: when TTS_PROVIDER is not "none", web TTS is disabled to avoid double audio.
WEB_AUDIO_ENABLED=false
WEB_STT_PROVIDER=openai
WEB_STT_MODEL=whisper-1
WEB_RECORDING_MAX_SECONDS=8
WEB_CONVERSATION_SILENCE_MS=900
WEB_CONVERSATION_IDLE_SECONDS=25
WEB_CONVERSATION_THRESHOLD=0.035
WEB_TTS_PROVIDER=openai
WEB_TTS_MODEL=gpt-4o-mini-tts
WEB_TTS_VOICE=alloy

# Enable debug logging
DEBUG=false

# MCP server log level (debug, info, warn, error)
MCP_LOG_LEVEL=info
