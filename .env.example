# Required API Keys
# OpenAI API key for Whisper (speech-to-text) and GPT models
OPENAI_API_KEY=your-openai-api-key-here

# Optional but Recommended
# ElevenLabs API key for high-quality text-to-speech
# Without this, the assistant will use the system TTS (pyttsx3)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Optional - Model Settings
# OpenAI model for the assistant (default: gpt-4)
# Options: gpt-4, gpt-4-turbo, gpt-3.5-turbo
OPENAI_MODEL=gpt-4

# Optional - Voice Settings
# ElevenLabs voice ID (default: Rachel)
# Browse available voices at https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=ZF6FPAbjXT4488VcRRnw

# Optional - Audio Settings
# Silence threshold for voice detection (default: 500)
# Lower values = more sensitive
VOICE_SILENCE_THRESHOLD=500

# Silence duration in seconds (default: 1.5)
# How long to wait after speech stops
VOICE_SILENCE_DURATION=1.5

# Optional - Assistant Configuration
# System prompt for the AI assistant
# Customize the assistant's personality and behavior
ASSISTANT_SYSTEM_PROMPT="You are a helpful voice assistant with access to various tools. Your name is mcp-use. Be concise in your responses since they will be spoken aloud. Summarize your results. Behave like a great motivational speaker, and motivate me throughout the conversation."

# Optional - MCP-provided Assistant Instructions
# When enabled, the assistant can load startup instructions from one configured MCP server.
# It tries MCP_PROMPT_NAME first, then MCP_PROMPT_RESOURCE_URI, then MCP_PROMPT_TOOL.
# The fallback tool is only called when explicitly configured here.
MCP_LOAD_SERVER_PROMPT=false
MCP_PROMPT_SERVER=mixer
MCP_PROMPT_NAME=xmseries_mixer_assistant
MCP_PROMPT_RESOURCE_URI=xmseries://prompt/system
MCP_PROMPT_TOOL=osc_get_agent_prompt
# Optional multi-server alternative. When set, this JSON list takes precedence over the single-source variables above.
# MCP_PROMPT_SOURCES=[{"server":"mixer","prompt_name":"xmseries_mixer_assistant"},{"server":"lights","resource_uri":"lights://prompt/system"}]
# append keeps the local assistant prompt before the loaded MCP prompts; replace uses only the loaded MCP prompts.
MCP_PROMPT_MERGE_MODE=append

# Optional - MCP Server Specific
# Linear API key for task management integration
# The Linear MCP server can also use browser-based authentication
LINEAR_API_KEY=your-linear-api-key-here

# GitHub personal access token for GitHub MCP server
GITHUB_PERSONAL_ACCESS_TOKEN=your-github-token-here

# GitLab configuration for GitLab MCP server
GITLAB_PERSONAL_ACCESS_TOKEN=your-gitlab-token-here
GITLAB_BASE_URL=https://gitlab.com

# PostgreSQL connection string for database MCP server
POSTGRES_CONNECTION_STRING=postgresql://user:password@localhost:5432/dbname

# Optional - Development Settings
# Enable debug logging
DEBUG=false

# MCP server log level (debug, info, warn, error)
MCP_LOG_LEVEL=info
