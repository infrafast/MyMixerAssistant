# Offline profile for Live Stage Assistant.
# Activate with: cp .env.offline .env

# Cloud API keys are intentionally empty in offline mode.
OPENAI_API_KEY_FILE=
ELEVENLABS_API_KEY_FILE=

# LLM provider selection
LLM_PROVIDER=ollama
OPENAI_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434

# Speech-to-text settings
STT_PROVIDER=local-whisper
LOCAL_WHISPER_MODEL=base
#STT_LANGUAGE=auto
STT_LANGUAGE=fr

# Text-to-speech settings
TTS_PROVIDER=pyttsx3
ELEVENLABS_VOICE_ID=1EmYoP3UnnnwhlJKovEy

# Audio settings
VOICE_SILENCE_THRESHOLD=500
VOICE_SILENCE_DURATION=1.5
THINKING_SOUND_FILE=thinking.wav

# Assistant prompt
# Leave empty to use the built-in prompt from voice_assistant/agent.py.
ASSISTANT_SYSTEM_PROMPT=
MCP_AGENT_MEMORY_ENABLED=true

# MCP configuration
MCP_CONFIG=mcp_servers.offline.json

# Optional MCP-provided startup instructions.
# Keep disabled unless your offline MCP server exposes prompts/resources/tools for startup instructions.
MCP_LOAD_SERVER_PROMPT=false
MCP_PROMPT_MERGE_MODE=append

# Optional MCP server credentials
LINEAR_API_KEY=
GITHUB_PERSONAL_ACCESS_TOKEN=
GITLAB_PERSONAL_ACCESS_TOKEN=
GITLAB_BASE_URL=https://gitlab.com
POSTGRES_CONNECTION_STRING=

# Logging
DEBUG=false
MCP_LOG_LEVEL=info
