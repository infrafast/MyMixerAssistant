{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["--offline", "-y", "@modelcontextprotocol/server-filesystem", "."],
      "env": {}
    },
    "memory": {
      "command": "npx",
      "args": ["--offline", "-y", "@modelcontextprotocol/server-memory"],
      "env": {}
    },
    "mixer": {
      "command": "node",
      "args": [
        "/Users/ts/Documents/PlatformIO/Projects/XMSeries-MCP/dist/index.js"
      ],
      "env": {
        "OSC_HOST": "192.168.0.1",
        "OSC_PORT": "10023",
        "OSC_PROTOCOL": "OSCXR",
        "DEBUG": "${DEBUG}"
      },
      "assistantPrompt": {
        "promptName": "xmseries_mixer_assistant",
        "resourceUri": "xmseries://prompt/system",
        "tool": "osc_get_agent_prompt"
      }
    }    
  }
}
